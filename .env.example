# ============================================================================
# LedgerFrame configuration — copy to `.env` and edit. NEVER commit `.env`.
# All values shown are safe defaults for a local, demo-mode install.
# ============================================================================

# --- Core ---
LEDGERFRAME_ENV=production                  # production | development
LEDGERFRAME_DATA_DIR=/mnt/ledgerframe-data  # USB NVMe mount; all mutable data lives here
LEDGERFRAME_API_HOST=127.0.0.1              # localhost-only by default. Change ONLY with auth.
LEDGERFRAME_API_PORT=8321
LEDGERFRAME_LOG_LEVEL=INFO

# --- Security ---
# A long random string used to sign session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
LEDGERFRAME_SECRET_KEY=change-me-to-a-long-random-string
# Set to true to allow access from other devices on the LAN. Requires a PIN.
LEDGERFRAME_ALLOW_LAN=false
# Auto-lock the UI after this many minutes of inactivity (0 disables).
LEDGERFRAME_AUTOLOCK_MINUTES=15

# --- Base currency & display ---
LEDGERFRAME_BASE_CURRENCY=SGD               # SGD | USD | INR | EUR | GBP | ...
LEDGERFRAME_TIMEZONE=Asia/Singapore

# --- Market data provider ---
# mock = synthetic DEMO data (no key needed). csv = local OHLCV files.
# Set to an external adapter name (e.g. "alphavantage") only after reviewing its licence.
LEDGERFRAME_MARKET_PROVIDER=mock
LEDGERFRAME_STALE_AFTER_SECONDS=900         # mark quotes stale after this long
# External provider key (only used when LEDGERFRAME_MARKET_PROVIDER is an external adapter)
LEDGERFRAME_MARKET_API_KEY=

# --- AI (Hailo) ---
LEDGERFRAME_AI_ENABLED=true                 # false disables AI entirely (deterministic fallback)
LEDGERFRAME_AI_PROVIDER=hailo               # hailo | disabled | openai_compatible
LEDGERFRAME_HAILO_BASE_URL=http://127.0.0.1:8000
LEDGERFRAME_AI_MODEL=                       # blank = auto-select smallest supported instruct model
LEDGERFRAME_AI_TIMEOUT_SECONDS=30
LEDGERFRAME_AI_MAX_REQUESTS_PER_MINUTE=20
# OpenAI-compatible provider (DISABLED unless explicitly configured; sends data off-device!)
LEDGERFRAME_OPENAI_BASE_URL=
LEDGERFRAME_OPENAI_API_KEY=

# --- Voice (optional, off by default) ---
LEDGERFRAME_VOICE_ENABLED=false
LEDGERFRAME_STT_PROVIDER=whispercpp         # whispercpp | vosk | disabled
LEDGERFRAME_TTS_PROVIDER=piper              # piper | disabled
LEDGERFRAME_WAKEWORD_ENABLED=false

# --- Backups ---
LEDGERFRAME_BACKUP_ENABLED=true
LEDGERFRAME_BACKUP_KEEP=14                   # rotate: keep this many encrypted backups
# Recipient public key for age encryption (generate with: age-keygen -o age-identity.txt)
LEDGERFRAME_BACKUP_AGE_RECIPIENT=

# --- Display / kiosk ---
LEDGERFRAME_KIOSK_URL=http://127.0.0.1:8321
LEDGERFRAME_ROTATION_DEFAULT_SECONDS=30
